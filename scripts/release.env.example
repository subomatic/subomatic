# Copy to scripts/release.env (GITIGNORED) and fill in for LOCAL signed releases.
# In CI these are injected from repo Variables + Secrets, not from this file.
#
#   cp scripts/release.env.example scripts/release.env   # then edit

# Non-secret identifiers (CI: repo Variables) ---------------------------------
export MACOS_SIGNING_IDENTITY="Developer ID Application: <Your Org> (<TEAMID>)"
export APPLE_TEAM_ID="<TEAMID>"

# Notarization via App Store Connect API key (CI: Secrets) --------------------
export APPLE_API_KEY_PATH="$HOME/path/to/AuthKey_XXXXXXXXXX.p8"
export APPLE_API_KEY_ID="XXXXXXXXXX"
export APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Subomatic",
  "version": "0.1.0",
  "identifier": "it.salamacchine.subomatic",
  "build": {
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "ZFc1MGNuVnpkR1ZrSUdOdmJXMWxiblE2SUcxcGJtbHphV2R1SUhCMVlteHBZeUJyWlhrNklEazRRamMyT1VRME5qWXdNekZDUWpBS1VsZFRkMGQzVG0weFIyMHpiVWRTZFVOaVVFcEljMHh5VFVoNUwxVmtUMDVETUdweGNUZE5SRGM1YTBKR01EQnZOblZqWlZOTmRYY0s=",
      "endpoints": [
        "https://github.com/subomatic/subomatic/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Subomatic",
        "width": 900,
        "height": 760,
        "minWidth": 520,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
